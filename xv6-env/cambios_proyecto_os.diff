diff --git a/kernel/kalloc.c b/kernel/kalloc.c
index 2fcec38..388f82f 100644
--- a/kernel/kalloc.c
+++ b/kernel/kalloc.c
@@ -28,6 +28,19 @@ kinit()
 {
   initlock(&kmem.lock, "kmem");
   freerange(end, (void *)PHYSTOP);
+
+  // PROYECTO OS: reporta la memoria fisica libre disponible justo
+  // despues de poblar kmem.freelist. Recorre la lista enlazada de
+  // paginas libres (struct run) para contarlas y mostrar el total
+  // en KB, dando visibilidad del estado inicial del asignador.
+  {
+    struct run *r;
+    uint64 freepages = 0;
+    for (r = kmem.freelist; r; r = r->next)
+      freepages++;
+    printk("memoria fisica libre: %d KB (%d paginas de %d bytes)\n",
+           (int)(freepages * PGSIZE / 1024), (int)freepages, (int)PGSIZE);
+  }
 }
 
